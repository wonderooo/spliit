# --- Database (Neon Postgres) ---------------------------------------------
# From the Neon dashboard (or Vercel Marketplace integration). Use the pooled
# connection string. Works for both local dev and production.
DATABASE_URL=""

# --- better-auth ----------------------------------------------------------
# Generate a 32+ char secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
# The canonical URL of the app. Localhost for dev, your domain in prod.
BETTER_AUTH_URL="http://localhost:3000"
# Public copy used by the browser auth client (same value).
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# --- Google OAuth ---------------------------------------------------------
# Google Cloud Console -> Credentials -> OAuth 2.0 Client ID (Web app).
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Receipt scanning (Google Gemini, free tier) --------------------------
# Free API key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Optional: override the model (default gemini-2.5-flash).
# GEMINI_MODEL="gemini-2.5-flash-lite"
